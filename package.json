{
    "name": "@devfamily/admiral",
    "description": "Admiral is a frontend framework for creating back office using React. It provides out-of-the-box components and tools that make developing an admin interface easy and fast.",
    "version": "5.12.3",
    "bugs": "https://github.com/dev-family/admiral/issues",
    "homepage": "https://github.com/dev-family/admiral",
    "repository": {
        "type": "git",
        "url": "https://github.com/dev-family/admiral"
    },
    "license": "MIT",
    "keywords": [
        "react",
        "admin",
        "reactjs",
        "admin-dashboard",
        "admin-ui",
        "admin-on-rest",
        "frontend-framework",
        "react-admin",
        "admin-template",
        "dashboard",
        "admin-panel",
        "developer-tools"
    ],
    "engines": {
        "node": ">=20.19.0"
    },
    "scripts": {
        "dev": "vite --host",
        "build": "tsc && vite build",
        "build:lib": "vite build --config vite-lib.config.js && tsc --project tsconfig-lib.json && rm -rf lib/pages lib/src",
        "serve": "vite preview",
        "prepare": "husky",
        "prettier:check": "prettier --check .",
        "prettier:write": "prettier --write .",
        "lint": "eslint admiral/ src/ pages/",
        "lint:fix": "eslint --fix admiral/ src/ pages/",
        "tsc": "tsc"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.json,.{eslintrc,prettierrc}": [
            "prettier --parser json --write"
        ],
        "*.{css,scss}": [
            "prettier --write"
        ],
        "*.{html,md,yml}": [
            "prettier --write"
        ]
    },
    "dependencies": {
        "@bem-react/classname": "^1.7.0",
        "@consta/uikit": "^5.32.0",
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@editorjs/editorjs": "^2.31.3",
        "@editorjs/header": "^2.8.1",
        "@editorjs/image": "^2.8.2",
        "@editorjs/nested-list": "^1.3.0",
        "@editorjs/paragraph": "^2.11.3",
        "@floating-ui/react": "^0.27.18",
        "@rc-component/context": "^2.0.1",
        "@tinymce/tinymce-react": "^6.3.0",
        "axios": "^1.7.0",
        "classnames": "^2.3.1",
        "date-fns": "^4.1.0",
        "qs": "^6.14.1",
        "rc-dialog": "^10.0.0",
        "rc-drawer": "^7.2.0",
        "rc-notification": "^5.6.2",
        "rc-pagination": "^5.1.0",
        "rc-picker": "^4.11.0",
        "rc-select": "^14.16.0",
        "rc-switch": "^4.1.0",
        "rc-table": "^7.49.0",
        "rc-tabs": "^15.5.0",
        "rc-upload": "^4.8.1",
        "rc-util": "^5.44.3",
        "react-color": "^2.19.3",
        "react-icons": "^5.5.0",
        "react-router-dom": "^7.1.0",
        "react-spring": "^10.0.3",
        "react-textarea-autosize": "^8.3.3",
        "slugify": "^1.6.5",
        "tinycolor2": "^1.4.2"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@types/qs": "^6.9.7",
        "@types/react": "^19.0.0",
        "@types/react-color": "^3.0.6",
        "@types/react-dom": "^19.0.0",
        "@types/react-ultimate-pagination": "^1.2.1",
        "@types/tinycolor2": "^1.4.3",
        "@vitejs/plugin-react": "^5.1.4",
        "eslint": "^9.0.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react-hooks": "^7.0.1",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "msw": "^2.7.0",
        "postcss": "^8.5.0",
        "postcss-color-mod-function": "^3.0.3",
        "prettier": "^3.8.1",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "sass": "^1.83.0",
        "typescript": "^5.7.0",
        "typescript-eslint": "^8.56.0",
        "vite": "^6.3.0"
    },
    "peerDependencies": {
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    },
    "msw": {
        "workerDirectory": "public"
    },
    "sideEffects": [
        "*.css",
        "*.scss"
    ],
    "files": [
        "lib"
    ],
    "main": "./lib/index.mjs",
    "module": "./lib/index.mjs",
    "types": "./lib/index.d.ts",
    "exports": {
        ".": {
            "import": "./lib/index.mjs",
            "types": "./lib/index.d.ts"
        },
        "./ui": {
            "import": "./lib/ui/index.mjs",
            "types": "./lib/ui/index.d.ts"
        },
        "./form": {
            "import": "./lib/form/index.mjs",
            "types": "./lib/form/index.d.ts"
        },
        "./auth": {
            "import": "./lib/auth/index.mjs",
            "types": "./lib/auth/index.d.ts"
        },
        "./crud": {
            "import": "./lib/crud/index.mjs",
            "types": "./lib/crud/index.d.ts"
        },
        "./theme": {
            "import": "./lib/theme/index.mjs",
            "types": "./lib/theme/index.d.ts"
        },
        "./locale": {
            "import": "./lib/locale/index.mjs",
            "types": "./lib/locale/index.d.ts"
        },
        "./style.css": "./lib/admiral.css"
    }
}
